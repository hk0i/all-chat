# Copy to .env and adjust. All values optional — defaults work out of the box.

# Hostname advertised to jwilder/nginx-proxy (docs/EDD.md §6).
#ALLCHAT_HOST=chat.example.com

# External Docker network shared with nginx-proxy.
#PROXY_NETWORK=proxy_network

# Kick's public Pusher key/cluster — override when Kick rotates them
# (docs/EDD.md §3.2 explains how to find the current values).
#KICK_PUSHER_KEY=32cbd69e4b950bf97679
#KICK_PUSHER_HOST=ws-us2.pusher.com
