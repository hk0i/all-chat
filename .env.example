# Copy to .env and adjust. All values optional — defaults work out of the box.

# Hostname advertised to jwilder/nginx-proxy (docs/EDD.md §6).
#ALLCHAT_HOST=chat.example.com

# External Docker network shared with nginx-proxy.
#PROXY_NETWORK=proxy_network

# Kick's public Pusher key/cluster — override when Kick rotates them
# (docs/EDD.md §3.2 explains how to find the current values).
#KICK_PUSHER_KEY=32cbd69e4b950bf97679
#KICK_PUSHER_HOST=ws-us2.pusher.com

# Platform OAuth (docs/EDD-V2.md §3) — connecting a platform unlocks sending
# messages through it; reading works anonymously either way. Redirect URI
# must be HTTPS (Twitch/Google both require it, localhost excepted) — see
# docs/EDD-V2.md §3 for what that means for a plain-HTTP LAN deployment.
# Twitch: register at https://dev.twitch.tv/console/apps
#TWITCH_CLIENT_ID=
#TWITCH_CLIENT_SECRET=
# Google (YouTube): register at https://console.cloud.google.com/apis/credentials
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
